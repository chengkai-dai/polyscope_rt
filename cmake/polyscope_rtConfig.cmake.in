@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/polyscope_rtTargets.cmake")

set_and_check(polyscope_rt_INCLUDE_DIR
  "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@")
set_and_check(polyscope_rt_SHADER_LIBRARY
  "${PACKAGE_PREFIX_DIR}/@POLYSCOPE_RT_SHADER_INSTALL_DIR@/metal_path_tracer_shaders.metallib")

function(polyscope_rt_copy_runtime_assets target_name)
  if(NOT TARGET "${target_name}")
    message(FATAL_ERROR "polyscope_rt_copy_runtime_assets(): target '${target_name}' does not exist")
  endif()

  add_custom_command(
    TARGET "${target_name}"
    POST_BUILD
    COMMAND "${CMAKE_COMMAND}" -E copy_if_different
            "${polyscope_rt_SHADER_LIBRARY}"
            "$<TARGET_FILE_DIR:${target_name}>/metal_path_tracer_shaders.metallib"
    VERBATIM
  )
endfunction()

check_required_components(polyscope_rt)
